#!/usr/bin/env bash
# my-dotfiles | Copyright (C) 2025 eth-p
# Repository: https://github.com/eth-p/my-dotfiles
#
# Apply device-specific configuration changes.
#
# Use `--dirty` to use local changes in my-dotfiles.
# ==============================================================================
# shellcheck shell=bash source-path=.
set -euo pipefail

# Run `my-dotfiles-build` with the `--apply` flag.
set -- "$@" --apply
cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
source "my-dotfiles-build"

# ------------------------------------------------------------------------------

# Delete neovim's Luajit cache if it gets too large.
if [[ "$(du -k "$HOME/.cache/nvim/luac" | awk '{ print $1 }')" -gt 65536 ]]; then
	find "$HOME/.cache/nvim/luac" -iname "%2fnix%2fstore%2f*.luac" | xargs rm
fi
